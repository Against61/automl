LLM_PROVIDER=openai
OPENAI_API_KEY=

CODEX_USE_OPENAI_API_KEY=true
CODEX_MODEL=gpt-5.3-codex-spark
CODEX_CLI_CMD=codex exec --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check

WORKER_CONCURRENCY=2
MAX_RUN_STEPS=20
CODEX_STEP_TIMEOUT_SEC=900
TRAINING_IDLE_TIMEOUT_SEC=3600
TRAINING_MAX_WALL_CLOCK_SEC=0
MAX_STDIO_BYTES=262144

EXECUTION_FAILURE_REPLAN_ENABLED=true
MAX_EXECUTION_REPLANS=1
MAX_QUALITY_REPLANS=3
PLAN_REVIEW_ENABLED=true
PLAN_REVIEW_MANUAL_FALLBACK=true
CONTRACT_STRICTNESS=balanced
CPU_TRAINING_BUDGET_EPOCH_TRIALS_LIMIT=120
RALPH_PRD_FILE_NAME=prd.json
RALPH_PROGRESS_FILE_NAME=progress.txt
RALPH_AUTO_QUEUE_NEXT_STORY=false
